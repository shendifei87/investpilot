# InvestPilot Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# ── Required ────────────────────────────────────────────────────────
# Tushare Pro API token (register at https://tushare.pro)
TUSHARE_TOKEN=

# ── Optional: Simulation ────────────────────────────────────────────
# Number of Monte Carlo simulation paths (default: 100000)
# MC_SIMS=100000

# Cache TTL in hours for fetched market data (default: 24)
# CACHE_TTL_HOURS=24

# ── Optional: Model Validation Tolerances ───────────────────────────
# Hybrid tolerance: tolerance = max(atol, rtol * |expected|)
# Financials (COGS, EBIT, FCF) — in millions (default: atol=5.0, rtol=0.001)
# MODEL_VAL_FIN_ATOL=5.0
# MODEL_VAL_FIN_RTOL=0.001

# EPS (basic/diluted) — in RMB per share (default: atol=0.01, rtol=0.02)
# MODEL_VAL_EPS_ATOL=0.01
# MODEL_VAL_EPS_RTOL=0.02

# Target price — in trading currency (default: atol=0.5, rtol=0.01)
# MODEL_VAL_TP_ATOL=0.5
# MODEL_VAL_TP_RTOL=0.01

# Gross margin — ratio (default: atol=0.001)
# MODEL_VAL_GM_ATOL=0.001

# Balance sheet gap warning threshold (default: 0.02 = 2%)
# MODEL_VAL_BS_GAP=0.02

# ── Optional: Web Dashboard ─────────────────────────────────────────
# Bearer token for API authentication (empty = no auth, localhost-only)
# INVESTPILOT_TOKEN=

# CORS allowed origin (empty = auto-detect from localhost)
# INVESTPILOT_CORS_ORIGIN=

# Root directory for workspace folders (default: ./workspaces)
# WORKSPACES_DIR=
